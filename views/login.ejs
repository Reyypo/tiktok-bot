<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<title>REST AREA Dashboard</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial,sans-serif;
}

body{
  background:#050505;
  color:white;
}

nav{
  width:100%;
  height:90px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 50px;
  border-bottom:1px solid rgba(255,255,255,.08);
}

.logo{
  font-size:32px;
  font-weight:900;
  color:#5865F2;
}

.logout{
  background:#5865F2;
  color:white;
  text-decoration:none;
  padding:14px 28px;
  border-radius:999px;
  font-weight:bold;
}

.container{
  display:flex;
  justify-content:center;
  align-items:center;
  min-height:calc(100vh - 90px);
}

.card{
  width:450px;
  background:#111;
  border-radius:30px;
  padding:40px;
  text-align:center;
  box-shadow:0 0 50px rgba(88,101,242,.15);
}

.avatar{
  width:140px;
  height:140px;
  border-radius:50%;
  border:4px solid #5865F2;
  object-fit:cover;
}

.username{
  font-size:38px;
  font-weight:900;
  margin-top:25px;
}

.userid{
  margin-top:12px;
  color:#aaa;
  font-size:17px;
}

.role-box{
  margin-top:30px;
  background:#181818;
  border-radius:20px;
  padding:20px;
}

.role-title{
  font-size:20px;
  font-weight:bold;
  margin-bottom:10px;
}

.role-text{
  color:#b9bbbe;
}

@media(max-width:600px){
  nav{
    padding:20px;
  }

  .card{
    width:90%;
  }

  .username{
    font-size:30px;
  }
}
</style>
</head>
<body>

<nav>
  <div class="logo">
    REST AREA
  </div>

  <a href="/logout" class="logout">
    Logout
  </a>
</nav>

<div class="container">

  <div class="card">

    <img
      class="avatar"
      src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png"
    />

    <div class="username">
      <%= user.username %>
    </div>

    <div class="userid">
      User ID: <%= user.id %>
    </div>

    <div class="role-box">
      <div class="role-title">
        Welcome to REST AREA Dashboard
      </div>

      <div class="role-text">
        Manage your server and account here.
      </div>
    </div>

  </div>

</div>

</body>
</html>